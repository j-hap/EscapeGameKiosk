<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
  xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal">

  <!--
    Bundle Id="EscapeGameKiosk.Bundle": human-readable UpgradeCode (WiX v6).
    The bundle UpgradeCode must differ from the MSI UpgradeCode, hence the suffix.

    .NET 10 Desktop Runtime: installed on demand by a deferred MSI custom action
    (dotnet-install.ps1 fetched from https://dot.net/v1/) when absent — requires
    internet access during setup.  WebView2 must be present on the target machine.
    See README.md § Prerequisites for details.
  -->
  <Bundle Name="EscapeGameKiosk"
    Id="EscapeGameKiosk.Bundle"
    Version="$(var.Version)"
    Manufacturer="EscapeGameKiosk">

    <!--
      Bundle variable that accepts the FORCEDOTNETINSTALL command-line override.
      Burn maps command-line arguments of the form VAR=value to bundle Variables.
      Default "0" means the custom action fires only when the runtime is absent.
    -->
    <Variable Name="FORCEDOTNETINSTALL" Value="0" Type="string" bal:Overridable="yes" />

    <!-- WixStdBA: license confirmation dialog showing the MIT license text inline -->
    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication
        Theme="rtfLicense"
        LicenseFile="..\LICENSE.rtf" />
    </BootstrapperApplication>

    <Chain>
      <!-- ── Main MSI (per-user, no elevation) ── -->
      <MsiPackage SourceFile="$(var.EscapeGameKiosk.Installer.TargetPath)"
        EnableFeatureSelection="no">
        <!--
          Forward the FORCEDOTNETINSTALL bundle variable to the MSI as a public
          property so the dotnet-install.ps1 custom action condition can read it.
          Pass FORCEDOTNETINSTALL=1 on the bundle command line to force the
          private runtime download even when DotNetCompatibilityCheck detects a
          system-wide runtime (useful for testing on dev machines).
        -->
        <MsiProperty Name="FORCEDOTNETINSTALL" Value="[FORCEDOTNETINSTALL]" />
      </MsiPackage>
    </Chain>
  </Bundle>

</Wix>
