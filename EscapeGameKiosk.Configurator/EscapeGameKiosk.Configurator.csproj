<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <AssemblyName>EscapeGameKioskConfigurator</AssemblyName>
    <RootNamespace>EscapeGameKiosk.Configurator</RootNamespace>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RuntimeIdentifiers>win-x64</RuntimeIdentifiers>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <!-- Generated by the GenerateAppIcon target below. -->
    <ApplicationIcon>Assets\AppIcon.ico</ApplicationIcon>
  </PropertyGroup>

  <!--
    No NuGet packages required: System.Text.Json ships with the .NET framework,
    Microsoft.Win32.OpenFileDialog is part of WPF (PresentationFramework).
  -->

  <!--
    Step 1 – Merge the two source SVGs into a composite logo.svg.
    lock.svg and gear.svg are the sole source of truth; logo.svg is generated.
    MSBuild skips this step when logo.svg is newer than both source files.
  -->
  <Target Name="MergeConfiguratorSvg" BeforeTargets="BeforeBuild"
    Inputs="$(MSBuildThisFileDirectory)..\EscapeGameKiosk\Assets\lock.svg;
            $(MSBuildProjectDirectory)\Assets\gear.svg"
    Outputs="$(MSBuildProjectDirectory)\Assets\logo.svg">
    <Exec
      Command="pwsh -NoProfile -NonInteractive -File &quot;$(MSBuildThisFileDirectory)..\tools\Merge-SvgIcons.ps1&quot; -BackgroundSvg &quot;$(MSBuildThisFileDirectory)..\EscapeGameKiosk\Assets\lock.svg&quot; -OverlaySvg &quot;$(MSBuildProjectDirectory)\Assets\gear.svg&quot; -Output &quot;$(MSBuildProjectDirectory)\Assets\logo.svg&quot;"
      WorkingDirectory="$(MSBuildProjectDirectory)" />
  </Target>

  <!--
    Step 2 – Render logo.svg to AppIcon.ico.
    Depends on MergeConfiguratorSvg so the two targets always run in order.
    MSBuild skips this step when AppIcon.ico is newer than logo.svg.
  -->
  <Target Name="GenerateAppIcon" BeforeTargets="BeforeBuild"
    DependsOnTargets="MergeConfiguratorSvg"
    Inputs="$(MSBuildProjectDirectory)\Assets\logo.svg"
    Outputs="$(MSBuildProjectDirectory)\Assets\AppIcon.ico">
    <Exec
      Command="dotnet run --project &quot;$(MSBuildThisFileDirectory)..\EscapeGameKiosk.IconGen\EscapeGameKiosk.IconGen.csproj&quot; --configuration Release -- &quot;$(MSBuildProjectDirectory)\Assets\logo.svg&quot; &quot;$(MSBuildProjectDirectory)\Assets\AppIcon.ico&quot;"
      WorkingDirectory="$(MSBuildProjectDirectory)" />
  </Target>
</Project>
